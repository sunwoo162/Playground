{
  "manifest_version": 3,
  "name": "학교 알리미",
  "description": "확장 아이콘을 누르면 학교 알리미 급식표와 시간표를 바로 엽니다.",
  "version": "1.0.1",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon.svg",
    "32": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "action": {
    "default_title": "학교 알리미 열기",
    "default_icon": {
      "16": "icons/icon.svg",
      "32": "icons/icon.svg",
      "48": "icons/icon.svg",
      "128": "icons/icon.svg"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html"
}
