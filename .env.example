# GitHub OAuth App 설정
# https://github.com/settings/developers 에서 OAuth App 생성 후 입력
GITHUB_CLIENT_ID=여기에_클라이언트_ID
GITHUB_CLIENT_SECRET=여기에_클라이언트_시크릿

# 세션 암호화 키 (아무 랜덤 문자열)
SESSION_SECRET=your-random-secret-key-here

# 서버 포트
PORT=3000

# 콜백 URL (배포 시 변경)
CALLBACK_URL=http://localhost:3000/auth/github/callback

# 나이스 급식 API
NEIS_API_KEY=여기에_나이스_API_키

# Twelve Data API
# 실제 키는 커밋하지 말고 서버 환경변수/시크릿에만 설정
TWELVE_DATA_BASE_URL=https://api.twelvedata.com
TWELVE_DATA_API_KEY=여기에_TWELVE_DATA_API_KEY
TWELVE_DATA_MOCK=false
