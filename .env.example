# GitHub OAuth App 설정
# https://github.com/settings/developers 에서 OAuth App 생성 후 입력
GITHUB_CLIENT_ID=여기에_클라이언트_ID
GITHUB_CLIENT_SECRET=여기에_클라이언트_시크릿

# 세션 암호화 키 (아무 랜덤 문자열)
SESSION_SECRET=your-random-secret-key-here

# 서버 포트
PORT=3000

# 콜백 URL (배포 시 변경)
CALLBACK_URL=http://localhost:3000/auth/github/callback
