# GitHub OAuth App 설정
# https://github.com/settings/developers 에서 OAuth App 생성 후 입력
GITHUB_CLIENT_ID=여기에_클라이언트_ID
GITHUB_CLIENT_SECRET=여기에_클라이언트_시크릿

# 세션 암호화 키 (아무 랜덤 문자열)
SESSION_SECRET=your-random-secret-key-here

# 서버 포트
PORT=3000

# 콜백 URL (배포 시 변경)
CALLBACK_URL=http://localhost:3000/auth/github/callback

# 나이스 급식 API
NEIS_API_KEY=여기에_나이스_API_키

# 한국투자증권 Open API
# 모의투자: https://openapivts.koreainvestment.com:29443
# 실전: https://openapi.koreainvestment.com:9443
KIS_BASE_URL=https://openapivts.koreainvestment.com:29443
KIS_APP_KEY=여기에_한국투자증권_APP_KEY
KIS_APP_SECRET=여기에_한국투자증권_APP_SECRET
KIS_ACCOUNT_NO=모의투자_계좌번호
KIS_MOCK=true
